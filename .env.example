OPENAI_API_KEY=

AIRBTICS_API_KEY=
AIRBTICS_BASE_URL=https://crap0y5bx5.execute-api.us-east-2.amazonaws.com/prod

BROWSERLESS_API_KEY=
# Host only — no path or ?token= query string
BROWSERLESS_BASE_URL=https://production-sfo.browserless.io
# Optional timeout for /smart-scrape in milliseconds
BROWSERLESS_TIMEOUT_MS=60000
# Set to 1 to test Domain Browserless fetch via npm run dev (requires BROWSERLESS_API_KEY)
FORCE_DOMAIN_BROWSER=

# Bright Data — REA listing scrape (primary import path when configured)
BRIGHTDATA_API_KEY=057f4111-c454-4220-84c6-56e438de4ffb
BRIGHTDATA_REA_DATASET_ID=gd_l3cvjh111l943r4awk
# Web Unlocker zone name — required for Domain import and REA search discovery
BRIGHTDATA_UNLOCKER_ZONE=listing_unlocker
# Optional scrape timeout in milliseconds (default 25000)
BRIGHTDATA_SCRAPE_TIMEOUT_MS=25000
# Optional REA dataset scrape timeout in milliseconds (default max(BRIGHTDATA_SCRAPE_TIMEOUT_MS, 60000))
BRIGHTDATA_REA_SCRAPE_TIMEOUT_MS=60000
# REA rent discover SERP crawl (default 180000) — used for lease rental band + comps
BRIGHTDATA_REA_DISCOVER_TIMEOUT_MS=180000

# Apify — REA listing import + rent comps (preferred when set; memo23/realestate-au-listings actor)
APIFY_API_KEY=
# Optional actor override (default qBUaDtdr6kYSBZE8J)
APIFY_REA_ACTOR_ID=
# Max listings per rent search (default 50)
APIFY_REA_MAX_LISTINGS=50
# Actor sync timeout in ms (default 240000)
APIFY_REA_TIMEOUT_MS=240000
# Shared Supabase comparable-search cache. Fail-open and enabled by default when
# service-role configuration exists; set false for an immediate kill switch.
APIFY_REA_COMPARABLE_CACHE_ENABLED=true
# Cache freshness: rentals 3 days, active sales 7 days, sold searches 30 days.
APIFY_REA_RENT_CACHE_TTL_HOURS=72
APIFY_REA_BUY_CACHE_TTL_HOURS=168
APIFY_REA_SOLD_CACHE_TTL_HOURS=720

# PropRadar — address → rental estimate (optional; not wired to lease brochure v1)
PROP_RADAR_API_KEY=

GOOGLE_MAPS_API_KEY=

QR_CODE_BASE_URL=http://localhost:3000

APP_ENV=development

# Managed delivery platform (cron + tenant STR email delivery)
DELIVERY_CRON_SECRET=
RESEND_API_KEY=
DELIVERY_FROM_EMAIL=StayPacks Delivery <reports@staypack.app>
# E2E script: npx tsx scripts/run-haven-delivery-e2e.mjs your@email.com
DELIVERY_TEST_EMAIL=
# Optional webhook for failed delivery runs (Slack-compatible JSON POST)
DELIVERY_ALERT_WEBHOOK_URL=

# Optional: agency id for unauthenticated brochure preview fallback (server only).
SALES_BROCHURE_PREVIEW_AGENCY_ID=
# Optional: agent name to use in brochure previews (default: Harvey Specter).
SALES_BROCHURE_PREVIEW_AGENT_NAME=Harvey Specter
